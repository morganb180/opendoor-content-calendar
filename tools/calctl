// Resolve access to the Connect API: cached tokens, else run the local OAuth flow.
async function canvaClient(config) {
  let tokens = canva.readTokens();
  if (!tokens) {
    tokens = await canva.authorizeInteractive(config, { log });
    canva.writeTokens(tokens);
    log("Canva authorized; token cached at ~/.config/opendoor-calendar/tokens.json (0600).");
  }
  return canva.createClient(config, tokens, { onTokens: t => canva.writeTokens(t) });
}
async function cmdCanvaPull(ctx) {
  const config = canva.readConnectConfig();
  if (!config.clientId) { console.error(canvaSetupGuide()); process.exit(1); }
  const force = !!ctx.opts.force;
  const data = loadData(ctx.dataPath);
  const all = [...data.posts, ...data.inventory];
  let targets;
  if (ctx.opts.all) targets = all.filter(r => extractCanvaId(r.canva));
  else {
    const ref = ctx.opts._[1];
    if (!ref) die("canva pull requires a design id (or --all)");
    const wantId = extractCanvaId(ref) || ref;
    targets = all.filter(r => extractCanvaId(r.canva) === wantId);
    if (!targets.length) die(`no calendar record has Canva id ${wantId}; add one first (import-canva) or check the id`);
  }
  if (!targets.length) { log("no records with a Canva id to pull"); return; }
  const client = await canvaClient(config);
  let updated = 0, unchanged = 0, failed = 0;
  for (const record of targets) {
    const designId = extractCanvaId(record.canva);
    try {
      const design = await client.getDesign(designId);
      const plan = canva.planDesignUpdate(record, design, { force });
      const changed = [];
      if (plan.title) { record.title = plan.title; changed.push("title"); }
      if (plan.needsImg) {
        const rel = `previews/canva/${designId}.jpg`;
        await canva.downloadTo(design.thumbnailUrl, path.join(ROOT, "previews", "canva", `${designId}.jpg`));
        optimizeCopy(path.join(ROOT, "previews", "canva", `${designId}.jpg`), message => console.warn(`WARN ${message}`));
        record.media = record.media || { img: "", slides: [], video: "" };
        record.media.img = rel;
        changed.push("media.img");
      }
      if (changed.length) {
        record.updatedAt = nowISO();
        appendActivity("canva-pull", record, { canva: designId, fields: changed });
        log(`${record.id} pulled ${designId}: updated ${changed.join(", ")} — "${record.title}"`);
        updated++;
      } else { log(`${record.id} pulled ${designId}: no changes (title/image already curated; use --force to overwrite)`); unchanged++; }
    } catch (err) {
      if (err instanceof canva.CanvaAuthError) { console.error(`calctl: Canva auth failed: ${err.message}`); process.exit(1); }
      warn(ctx, `${record.id} (${designId}): ${err.message}`);
      failed++;
    }
  }
  if (updated) saveData(ctx.dataPath, data);
  log(`canva pull: ${updated} updated, ${unchanged} unchanged${failed ? `, ${failed} failed` : ""}`);
  finish(ctx);
}
async function cmdCanva(argv) {
  const ctx = context(argv);
  const sub = ctx.opts._[0];
  if (sub === "pull") return cmdCanvaPull(ctx);
  if (sub === "logout") { canva.clearTokens(); return log("cleared cached Canva tokens"); }
  if (sub === "selftest") return canvaSelftest();
