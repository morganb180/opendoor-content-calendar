}
function canvaSetupGuide() {
  return [
    "calctl canva pull needs a Canva Connect integration (one-time setup):",
    "",
    "  1. Sign in at https://www.canva.com/developers/ and create an integration",
    "     (Developers → Your integrations → Create an integration → \"Public\" or \"Private\").",
    "  2. Under \"Scopes\", enable:  design:meta:read",
    "  3. Under \"Authentication → Redirect URLs\", add:  http://127.0.0.1/callback",
    "     (Canva accepts any 127.0.0.1 port for a loopback redirect; the CLI picks a free one.)",
    "  4. Copy the Client ID. Provide it one of these two ways:",
    "        export CANVA_CLIENT_ID=OC-xxxxxxxxxxxx",
    "     or ~/.config/opendoor-calendar/config.json:  { \"clientId\": \"OC-xxxx\" }",
    "     If your integration issued a client secret, add CANVA_CLIENT_SECRET / \"clientSecret\" too.",
