}
const STATUSES = ["draft", "ready", "scheduled", "posted"];
function cmdAdd(argv) {
  const ctx = context(argv), args = ctx.opts, data = loadData(ctx.dataPath);
  if (args.date && args.inventory) die("--date and --inventory are mutually exclusive");
  if (args.date) assertDate(args.date);
  if (args.status && !STATUSES.includes(args.status)) die(`status must be one of: ${STATUSES.join("|")}`);
  const item = baseItem(args, data, ctx);
  if (args.date) {
    data.posts.push({ ...item, date: args.date, holiday: args.holiday || "", postedUrl: args.postedUrl || "" });
    log(`${item.id} scheduled ${args.date}: "${item.title}" [${item.status}]`);
  } else {
    if (args.holiday) warn(ctx, "--holiday only applies to scheduled posts; ignored for inventory");
    data.inventory.push(item);
    log(`${item.id} added to inventory: "${item.title}" [${item.status}]`);
  }
  saveData(ctx.dataPath, data); appendActivity("add", item, { date: args.date || "", inventory: !args.date }); finish(ctx);
}
function cmdSchedule(argv) {
  const ctx = context(argv), [ref, date] = ctx.opts._, data = loadData(ctx.dataPath); assertDate(date);
  const { item, kind } = findItem(data, ref);
  if (kind === "post") die(`${item.id} is already on the calendar (${item.date}); use calctl move`);
  data.inventory = data.inventory.filter(x => x.id !== item.id);
  data.posts.push({ ...item, status: "scheduled", date, holiday: item.holiday || "", postedUrl: item.postedUrl || "", updatedAt: nowISO() });
  saveData(ctx.dataPath, data); appendActivity("schedule", item, { date }); log(`${item.id} scheduled ${date}: "${item.title}" (moved from inventory, id preserved)`);
}
function cmdMove(argv) {
  const ctx = context(argv), [ref, date] = ctx.opts._, data = loadData(ctx.dataPath); assertDate(date);
  const { item, kind } = findItem(data, ref); if (kind !== "post") die(`${item.id} is inventory; use schedule`);
  const from = item.date; item.date = date; item.updatedAt = nowISO(); saveData(ctx.dataPath, data); appendActivity("move", item, { from, date }); log(`${item.id} moved ${from} -> ${date}: "${item.title}"`);
}
function coerce(value) { if (value === "true") return true; if (value === "false") return false; return value; }
function assign(item, key, value) {
  const parts = key.split("."); let target = item;
  while (parts.length > 1) { const part = parts.shift(); target[part] = target[part] || {}; target = target[part]; }
  target[parts[0]] = coerce(value);
}
function cmdSet(argv) {
  const ctx = context(argv), [ref, ...pairs] = ctx.opts._, data = loadData(ctx.dataPath); if (!pairs.length) die("set requires key=value [...]");
  const { item, kind } = findItem(data, ref);
  const changed = [];
  pairs.forEach(pair => {
    const idx = pair.indexOf("="); if (idx < 1) die(`invalid assignment: ${pair}`);
    let key = pair.slice(0, idx); const value = pair.slice(idx + 1);
    if (key === "img" || key === "video") key = "media." + key;
    if (key === "status" && !STATUSES.includes(value)) die(`status must be one of: ${STATUSES.join("|")}`);
    if (key === "theme") assertTheme(data, value);
    if (key === "date") { if (kind !== "post") die(`${item.id} is inventory; use calctl schedule to give it a date`); assertDate(value); }
    if ((key === "holiday" || key === "postedUrl") && kind !== "post") die(`${key} only applies to scheduled posts`);
    if (key === "canva" && value) assign(item, key, normalizeCanva(value));
    else if (key === "slides" || key === "media.slides") item.media = { ...(item.media || {}), slides: value ? value.split(",").map(s => s.trim()).filter(Boolean) : [] };
