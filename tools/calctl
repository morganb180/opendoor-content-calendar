}
function cmdRm(argv) {
  const ctx = context(argv), [ref] = ctx.opts._, data = loadData(ctx.dataPath); if (!ref) die("rm requires <id|title>");
  const { item, kind } = findItem(data, ref); data.posts = data.posts.filter(x => x.id !== item.id); data.inventory = data.inventory.filter(x => x.id !== item.id); const hadComments = !!data.comments[item.id]; delete data.comments[item.id]; saveData(ctx.dataPath, data); appendActivity("rm", item, { kind, hadComments }); log(`${item.id} removed from ${kind === "post" ? "calendar" : "inventory"}: "${item.title}"${hadComments ? " (comments deleted)" : ""}`);
