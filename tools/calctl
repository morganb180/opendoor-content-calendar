function cmdList(argv) {
  const ctx = context(argv), data = loadData(ctx.dataPath);
  let items = ctx.opts.inventory ? data.inventory.slice() : data.posts.slice().sort((a, b) => (a.date || "").localeCompare(b.date || ""));
  if (ctx.opts.month) {
    if (!/^\d{4}-\d{2}$/.test(ctx.opts.month)) die(`--month must be YYYY-MM`);
    items = items.filter(x => (x.date || "").startsWith(ctx.opts.month + "-"));
  }
  if (ctx.opts.status) {
    if (!STATUSES.includes(ctx.opts.status)) die(`status must be one of: ${STATUSES.join("|")}`);
    items = items.filter(x => x.status === ctx.opts.status);
  }
  if (ctx.opts.json) return console.log(JSON.stringify(items, null, 2));
  items.forEach(item => console.log(`${item.id}\t${item.date || "inventory"}\t${item.status}\t${item.theme}\t${item.title}${item.canva ? "\tcanva:" + item.canva : ""}`));
