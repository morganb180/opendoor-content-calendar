function cmdOptimizeImages() { runNode("scripts/optimize-images.js"); }
function git(args) { return spawnSync("git", ["-C", ROOT, ...args], { encoding: "utf8" }); }
function cmdDeploy(argv) {
  const ctx = context(argv);
  if (ctx.opts.data) console.warn("WARN --data is ignored by deploy; it validates and commits data/calendar.json");
  const v = runValidator(DEFAULT_DATA);
  if (v.stderr) process.stderr.write(v.stderr);
  if (v.status !== 0) die("validation failed; fix errors before deploying");
  log("validation passed");
  // Stage first so we can detect a no-op deploy before logging any activity.
  if (git(["add", "data", "previews"]).status !== 0) die(`git add failed`);
  if (git(["diff", "--cached", "--quiet"]).status === 0) { log("nothing to deploy: data/ and previews/ are unchanged"); return; }
  // Log the deploy BEFORE committing so the activity entry ships in the same commit.
  const message = ctx.opts.message || "Update calendar data";
  const data = loadData(DEFAULT_DATA);
  appendActivity(ctx.opts["no-push"] ? "deploy" : "publish", null, { message, posts: (data.posts || []).length, inventory: (data.inventory || []).length });
  git(["add", "data/activity.jsonl"]);
  const commit = git(["commit", "-m", message]);
  if (commit.status !== 0) die(`git commit failed: ${(commit.stderr || commit.stdout || "").trim()}`);
  log((commit.stdout || "").trim().split("\n")[0]);
  if (ctx.opts["no-push"]) { log("committed (push skipped via --no-push)"); return; }
  const push = git(["push"]);
  if (push.status !== 0) {
    const out = (push.stderr || "").trim();
    if (/non-fast-forward|fetch first|rejected/i.test(out)) die("push rejected (non-fast-forward). Run `git pull --rebase`, re-run tools/calctl validate, then `git push`. Never force-push.");
