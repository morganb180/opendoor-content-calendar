Commands:
  add --title T --theme brand --fmt "Static · 4:5" [--date YYYY-MM-DD|--inventory] [--img path] [--slides dir-or-glob] [--video URL|path] [--allow-local] [--canva ID|url] [--caption text] [--social-caption text] [--holiday text] [--status draft|ready|scheduled|posted]
      (no --date and no --inventory -> goes to inventory)
  schedule <id|title> <date>      inventory -> calendar, id preserved
  move <id|title> <date>          reschedule a post
  set <id|title> key=value [...]  e.g. status=posted postedUrl=... img=... media.video=...
  rm <id|title>                   removes the item and its comments
  list [--month YYYY-MM] [--inventory] [--status ready] [--json]
  import-canva "URL[, date, theme, title, caption]" [...]   [--theme brand] [--fmt "Static · 4:5"]
  canva pull <id|--all> [--force]   fetch title/thumbnail via Canva Connect (local OAuth)
  canva logout                      clear the cached Canva token
  validate [--json]
  optimize-images
  deploy [-m "message"] [--no-push]

