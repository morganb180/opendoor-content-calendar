}

// Hidden subcommand: exercises the Connect plumbing that can't touch the real
// API (PKCE math, auth-URL shape, token cache I/O, exchange/refresh bodies,
// 401→refresh→retry, thumbnail download, and the pure pull-plan logic) against
// mocked fetch + a temp dir. `node tools/calctl canva selftest`
async function canvaSelftest() {
  const os = require("os"), assert = require("assert");
  const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "calctl-canva-"));
  let n = 0; const ok = (name) => { n++; log(`ok ${n} - ${name}`); };
  try {
    // 1. PKCE: recompute S256 independently and confirm the verifier is RFC-legal.
    const verifier = canva.createVerifier();
    assert.match(verifier, /^[A-Za-z0-9_-]{43,128}$/, "verifier charset/length");
    const expect = require("crypto").createHash("sha256").update(verifier).digest("base64").replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
    assert.strictEqual(canva.challengeFor(verifier), expect, "S256 challenge");
    ok("PKCE verifier + S256 challenge");

    // 2. Authorize URL shape.
    const url = new URL(canva.buildAuthorizeUrl({ clientId: "OC-test", redirectUri: "http://127.0.0.1:5555/callback", codeChallenge: expect, state: "st8", scopes: canva.SCOPES }));
    assert.strictEqual(url.origin + url.pathname, "https://www.canva.com/api/oauth/authorize");
    assert.strictEqual(url.searchParams.get("response_type"), "code");
    assert.strictEqual(url.searchParams.get("client_id"), "OC-test");
    assert.strictEqual(url.searchParams.get("redirect_uri"), "http://127.0.0.1:5555/callback");
    assert.strictEqual(url.searchParams.get("scope"), "design:meta:read");
    assert.strictEqual(url.searchParams.get("code_challenge_method"), "S256");
    assert.strictEqual(url.searchParams.get("code_challenge"), expect);
    assert.strictEqual(url.searchParams.get("state"), "st8");
    ok("authorize URL construction");

    // 3. Token cache read/write with 0600 perms.
    const tokFile = path.join(tmp, "tokens.json");
    canva.writeTokens({ access_token: "a", refresh_token: "r", expires_in: 3600 }, tokFile);
    assert.strictEqual(fs.statSync(tokFile).mode & 0o777, 0o600, "token file perms 0600");
    assert.strictEqual(canva.readTokens(tokFile).access_token, "a", "token round-trip");
    assert.strictEqual(canva.readTokens(path.join(tmp, "nope.json")), null, "missing token file → null");
    ok("token cache read/write (0600)");

    // 4. exchangeCode / refreshTokens: correct endpoint + urlencoded body.
    let captured;
    const okJson = (obj) => ({ ok: true, status: 200, json: async () => obj });
    const capFetch = (u, opts) => { captured = { u, opts, body: opts.body.toString(), headers: opts.headers }; return okJson({ access_token: "AT", refresh_token: "RT", expires_in: 3600 }); };
    const pub = { clientId: "OC-pub", clientSecret: "" };
    await canva.exchangeCode(pub, { code: "CODE", codeVerifier: verifier, redirectUri: "http://127.0.0.1:1/callback" }, capFetch);
    assert.strictEqual(captured.u, "https://api.canva.com/rest/v1/oauth/token");
    const bp = new URLSearchParams(captured.body);
    assert.strictEqual(bp.get("grant_type"), "authorization_code");
    assert.strictEqual(bp.get("code"), "CODE");
    assert.strictEqual(bp.get("code_verifier"), verifier);
    assert.strictEqual(bp.get("redirect_uri"), "http://127.0.0.1:1/callback");
    assert.strictEqual(bp.get("client_id"), "OC-pub", "public client → client_id in body");
    assert.ok(!captured.headers.Authorization, "public client → no Basic header");
    // Confidential client → Basic auth header, no client_id in body.
    await canva.refreshTokens({ clientId: "OC-conf", clientSecret: "sh" }, "RT", capFetch);
    assert.strictEqual(new URLSearchParams(captured.body).get("grant_type"), "refresh_token");
    assert.strictEqual(captured.headers.Authorization, "Basic " + Buffer.from("OC-conf:sh").toString("base64"), "confidential → Basic header");
    ok("token exchange + refresh request bodies");

    // 5. designs response normalization.
    const norm = canva.normalizeDesignResponse({ design: { id: "DAH1", title: "  Fireworks  ", thumbnail: { url: "https://x/y.jpg" } } });
    assert.deepStrictEqual(norm, { id: "DAH1", title: "Fireworks", thumbnailUrl: "https://x/y.jpg" });
    ok("design response normalization");

    // 6. client 401 → refresh → retry, persisting new tokens.
    let calls = 0, saved = null;
    const flakyFetch = (u, opts) => {
      if (u.startsWith("https://api.canva.com/rest/v1/designs/")) {
        calls++;
        if (opts.headers.Authorization === "Bearer AT") return okJson({ design: { id: "DAHx", title: "T", thumbnail: { url: "u" } } });
        return { ok: false, status: 401, text: async () => "expired" };
      }
      return okJson({ access_token: "AT", refresh_token: "RT2", expires_in: 3600 }); // refresh
    };
    const client = canva.createClient(pub, { access_token: "OLD", refresh_token: "RT" }, { fetchImpl: flakyFetch, onTokens: t => { saved = t; } });
    const design = await client.getDesign("DAHx");
    assert.strictEqual(design.title, "T");
    assert.strictEqual(calls, 2, "one 401 then one success");
    assert.strictEqual(saved.access_token, "AT", "refreshed token persisted via onTokens");
    ok("client 401 → refresh → retry");

    // 7. 403 / 404 → typed CanvaApiError.
    for (const code of [403, 404]) {
      const c = canva.createClient(pub, { access_token: "AT", refresh_token: "RT" }, { fetchImpl: async () => ({ ok: false, status: code, text: async () => "" }) });
      await assert.rejects(() => c.getDesign("DAHz"), e => e instanceof canva.CanvaApiError && e.status === code);
    }
    ok("403/404 → CanvaApiError");

    // 8. planDesignUpdate: placeholder titles/empty img update; curated ones are protected unless --force.
    const design8 = { id: "D", title: "Real Title", thumbnailUrl: "https://t/x.jpg" };
    assert.deepStrictEqual(canva.planDesignUpdate({ title: "Canva design D", media: { img: "" } }, design8), { title: "Real Title", needsImg: true }, "placeholder + no img → both");
    assert.deepStrictEqual(canva.planDesignUpdate({ title: "Curated Name", media: { img: "previews/x.png" } }, design8), { title: null, needsImg: false }, "curated → protected");
    assert.deepStrictEqual(canva.planDesignUpdate({ title: "Curated Name", media: { img: "previews/x.png" } }, design8, { force: true }), { title: "Real Title", needsImg: true }, "force overrides");
    assert.deepStrictEqual(canva.planDesignUpdate({ title: "Untitled Canva import", media: { img: "previews/x.png" } }, design8), { title: "Real Title", needsImg: false }, "placeholder title but keep existing img");
    ok("planDesignUpdate title/image protection + force");

    // 9. thumbnail download to a temp file via mocked fetch.
    const bytes = Buffer.from([0xff, 0xd8, 0xff, 0x00, 0x11, 0x22]);
    const dest = path.join(tmp, "thumb.jpg");
    const size = await canva.downloadTo("https://t/x.jpg", dest, async () => ({ ok: true, status: 200, arrayBuffer: async () => bytes }));
    assert.strictEqual(size, bytes.length);
    assert.deepStrictEqual(fs.readFileSync(dest), bytes, "downloaded bytes match");
    ok("thumbnail download");

    log(`# all ${n} Canva selftest checks passed`);
  } finally {
    try { fs.rmSync(tmp, { recursive: true, force: true }); } catch { /* best effort */ }
  }
}

const [cmd, ...argv] = process.argv.slice(2);
(async () => {
  if (!cmd || cmd === "help" || cmd === "--help") usage();
  else if (cmd === "add") cmdAdd(argv);
  else if (cmd === "schedule") cmdSchedule(argv);
  else if (cmd === "move") cmdMove(argv);
  else if (cmd === "set") cmdSet(argv);
  else if (cmd === "rm") cmdRm(argv);
  else if (cmd === "list") cmdList(argv);
  else if (cmd === "import-canva") cmdImportCanva(argv);
  else if (cmd === "canva") await cmdCanva(argv);
  else if (cmd === "validate") cmdValidate(argv);
  else if (cmd === "optimize-images") cmdOptimizeImages(argv);
  else if (cmd === "deploy") cmdDeploy(argv);
  else die(`unknown command: ${cmd}`);
})().catch(err => die(err.message));
