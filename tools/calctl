function cmdImportCanva(argv) {
  const ctx = context(argv), rows = ctx.opts._, data = loadData(ctx.dataPath); if (!rows.length) die("import-canva requires at least one row");
  if (ctx.opts.theme) assertTheme(data, ctx.opts.theme);
  const defaults = { theme: ctx.opts.theme || "brand", fmt: ctx.opts.fmt || "Static · 4:5" };
  const existing = new Set([...data.posts, ...data.inventory].map(x => extractCanvaId(x.canva)).filter(Boolean));
  const seen = new Set();
  let addedPosts = 0, addedInv = 0, skipped = 0;
  // Args may hold multi-line pastes; lines without clean fields may still carry several links.
  const lines = rows.flatMap(r => String(r).split(/\r?\n/)).map(x => x.trim()).filter(Boolean);
  lines.forEach(line => {
    const parsedItems = [];
    const one = parseCanvaImportLine(line, defaults, themeKeys(data));
    if (one) parsedItems.push(one);
    else canvaLinksFrom(line).forEach(link => { const li = parseCanvaImportLine(link, defaults, themeKeys(data)); if (li) parsedItems.push(li); });
    if (!parsedItems.length) die(`no Canva design id found in: ${line}`);
    parsedItems.forEach(parsed => {
      const cid = extractCanvaId(parsed.canva);
      if (seen.has(cid)) return;
      seen.add(cid);
      if (existing.has(cid)) { log(`skip ${cid}: already on the calendar`); skipped++; return; }
      const item = { id: uid(), status: parsed.targetDate && !ctx.opts.inventory ? "scheduled" : "ready", title: parsed.title, theme: parsed.theme, fmt: parsed.fmt, caption: parsed.caption, socialCaption: parsed.socialCaption, canva: parsed.canva, media: { img: "", slides: [], video: "" }, updatedAt: nowISO() };
