      if (!media.img) media.img = posterFromVideo(args.video.replace(/^~/, process.env.HOME || "/Users/morganbrown"), id, { warn: message => warn(ctx, message) }) || "";
    } else die(`Local videos are not committed here. Upload ${args.video} to canva-asset-host or another https host, then rerun with --video URL. Use --allow-local only for Morgan-machine-only playback.`);
  }
  if (!media.img && media.slides.length) media.img = media.slides[0];
